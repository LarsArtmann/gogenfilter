---
import { useCases, useCaseIcons } from '../data/sections';
---

<div class="text-center mb-12">
  <h2 class="text-[clamp(1.875rem,4vw,2.25rem)] font-bold text-text-primary mb-4">Built for real tools.</h2>
  <p class="text-lg text-text-muted mb-12">Drop it into any linter, analyzer, or CI pipeline.</p>
</div>

<div class="grid gap-4 sm:grid-cols-3">
  {useCases.map((useCase) => (
    <div class="p-5 rounded-xl border border-border bg-bg-card text-center">
      <svg class="mx-auto mb-2 text-text-secondary" width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={useCaseIcons[useCase.icon]}/>
      </svg>
      <h3 class="font-semibold text-text-primary text-sm mb-1">{useCase.title}</h3>
      <p class="text-xs text-text-muted">{useCase.desc}</p>
    </div>
  ))}
</div>
