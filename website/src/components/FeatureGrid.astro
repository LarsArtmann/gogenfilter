---
import { features } from '../data/features';
import Icon from './Icon.astro';
import Card from './Card.astro';
import SectionHeader from './SectionHeader.astro';
import type { AccentColor } from '../data/types';

const iconColor: Record<AccentColor, string> = {
  accent: 'text-accent bg-accent-dim',
  amber: 'text-amber bg-amber/10',
  success: 'text-success bg-success/10',
};
---

<div>
  <SectionHeader title="Built to do one thing well." subtitle="No magic, no bloat. Just fast, accurate detection you can drop into any pipeline." />

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {features.map((feature) => (
      <Card variant="feature" class="hover:border-border-hover hover:-translate-y-0.5 transition-all duration-200">
        <div class={`inline-flex w-11 h-11 items-center justify-center rounded-lg mb-4 ${iconColor[feature.accent]}`}>
          <Icon name={feature.icon} />
        </div>
        <h3 class="font-semibold text-text-primary mb-2 text-lg">{feature.title}</h3>
        <p class="text-base text-text-muted leading-relaxed">{feature.desc}</p>
      </Card>
    ))}
  </div>
</div>
