---
import { features, icons } from '../data/features';
import Card from './Card.astro';
---

<div>
  <div class="text-center mb-12">
    <h2 class="text-[clamp(1.875rem,4vw,2.25rem)] font-bold text-text-primary mb-4">Engineered for performance.</h2>
    <p class="text-lg text-text-muted">Every API decision optimized for real-world static analysis pipelines.</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {features.map((feature) => (
      <Card variant="feature">
        <div class="text-accent mb-3" set:html={icons[feature.icon]} />
        <h3 class="font-semibold text-text-primary mb-2">{feature.title}</h3>
        <p class="text-sm text-text-muted leading-relaxed">{feature.desc}</p>
      </Card>
    ))}
  </div>
</div>
