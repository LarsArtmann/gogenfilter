---
import PhaseSection from './PhaseSection.astro';
import ComparisonSection from './ComparisonSection.astro';
import UseCasesSection from './UseCasesSection.astro';
import CTASection from './CTASection.astro';
import Section from './Section.astro';

const sections = [
  { component: PhaseSection, key: 'phase', tone: 'raised' as const },
  { component: ComparisonSection, key: 'comparison', tone: 'default' as const },
  { component: UseCasesSection, key: 'usecases', tone: 'raised' as const },
  { component: CTASection, key: 'cta', tone: 'default' as const },
] as const;
---

{sections.map(({ component: SectionComponent, tone }) => (
  <Section width="narrow" tone={tone} class="text-center">
    <SectionComponent />
  </Section>
))}
