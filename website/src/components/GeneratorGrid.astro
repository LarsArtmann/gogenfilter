---
const generators = [
  { name: 'sqlc', file: '.sql.go' },
  { name: 'templ', file: '_templ.go' },
  { name: 'protobuf', file: '.pb.go' },
  { name: 'go-enum', file: '_enum.go' },
  { name: 'mockgen', file: '_mock.go' },
  { name: 'moq', file: '_moq.go' },
  { name: 'wire', file: 'wire_gen.go' },
  { name: 'oapi-codegen', file: '.gen.go' },
  { name: 'deepcopy-gen', file: 'zz_generated.*' },
  { name: 'stringer', file: 'content marker' },
  { name: 'generic', file: 'Code generated by' },
];
---

<div>
  <div class="text-center" style="margin-bottom: 3rem;">
    <h2 class="section-title">11 generators. One filter.</h2>
    <p class="section-desc">Detects output from every major Go code generation tool.</p>
  </div>

  <div class="generator-grid">
    {generators.map((gen) => (
      <div class="generator-card">
        <div class="generator-name">{gen.name}</div>
        <div class="generator-file">{gen.file}</div>
      </div>
    ))}
  </div>
</div>
