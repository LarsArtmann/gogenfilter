---
const generators = [
  { name: 'sqlc', file: '.sql.go', url: 'https://sqlc.dev', logo: '/logos/sqlc.svg' },
  { name: 'templ', file: '_templ.go', url: 'https://templ.guide', logo: '/logos/templ.svg' },
  { name: 'protobuf', file: '.pb.go', url: 'https://protobuf.dev', logo: '/logos/protobuf.svg' },
  { name: 'go-enum', file: '_enum.go', url: 'https://github.com/abice/go-enum', logo: '/logos/go-enum.svg' },
  { name: 'mockgen', file: '_mock.go', url: 'https://github.com/golang/mock', logo: '/logos/mockgen.svg' },
  { name: 'moq', file: '_moq.go', url: 'https://github.com/matryer/moq', logo: '/logos/moq.svg' },
  { name: 'wire', file: 'wire_gen.go', url: 'https://github.com/google/wire', logo: '/logos/wire.svg' },
  { name: 'oapi-codegen', file: '.gen.go', url: 'https://github.com/oapi-codegen/oapi-codegen', logo: '/logos/oapi-codegen.svg' },
  { name: 'deepcopy-gen', file: 'zz_generated.*', url: 'https://github.com/kubernetes/gengo', logo: '/logos/deepcopy-gen.svg' },
  { name: 'stringer', file: 'content marker', url: 'https://pkg.go.dev/golang.org/x/tools/cmd/stringer', logo: '/logos/stringer.svg' },
  { name: 'generic', file: 'Code generated by', url: '', logo: '/logos/generic.svg' },
];
---

<div>
  <div class="text-center mb-12">
    <h2 class="text-[clamp(1.875rem,4vw,2.25rem)] font-bold text-text-primary mb-4">11 generators. One filter.</h2>
    <p class="text-lg text-text-muted">Detects output from every major Go code generation tool.</p>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
    {generators.map((gen) => (
      gen.url ? (
        <a href={gen.url} target="_blank" rel="noopener noreferrer" class="p-4 rounded-xl border border-border bg-bg-card hover:border-accent/30 hover:bg-bg-card-solid transition-all duration-200 block no-underline">
          <div class="flex items-center gap-2 mb-1">
            <img src={gen.logo} alt="" class="w-6 h-6" width="24" height="24" />
            <span class="font-semibold text-text-primary text-sm">{gen.name}</span>
            <svg class="ml-auto text-text-muted" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </div>
          <div class="text-xs text-text-muted font-mono">{gen.file}</div>
        </a>
      ) : (
        <div class="p-4 rounded-xl border border-border bg-bg-card">
          <div class="flex items-center gap-2 mb-1">
            <img src={gen.logo} alt="" class="w-6 h-6" width="24" height="24" />
            <span class="font-semibold text-text-primary text-sm">{gen.name}</span>
          </div>
          <div class="text-xs text-text-muted font-mono">{gen.file}</div>
        </div>
      )
    ))}
  </div>

  <p class="text-center mt-6 text-sm text-text-muted">
    Built by <a href="https://larsartmann.com" target="_blank" rel="noopener noreferrer" class="text-accent font-semibold hover:underline">LarsArtmann</a>
  </p>
</div>
