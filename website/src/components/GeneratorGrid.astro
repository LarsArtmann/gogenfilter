---
const generators = [
  { name: 'sqlc', file: '.sql.go', url: 'https://sqlc.dev' },
  { name: 'templ', file: '_templ.go', url: 'https://templ.guide' },
  { name: 'protobuf', file: '.pb.go', url: 'https://protobuf.dev' },
  { name: 'go-enum', file: '_enum.go', url: 'https://github.com/abice/go-enum' },
  { name: 'mockgen', file: '_mock.go', url: 'https://github.com/golang/mock' },
  { name: 'moq', file: '_moq.go', url: 'https://github.com/matryer/moq' },
  { name: 'wire', file: 'wire_gen.go', url: 'https://github.com/google/wire' },
  { name: 'oapi-codegen', file: '.gen.go', url: 'https://github.com/oapi-codegen/oapi-codegen' },
  { name: 'deepcopy-gen', file: 'zz_generated.*', url: 'https://github.com/kubernetes/gengo' },
  { name: 'stringer', file: 'content marker', url: 'https://pkg.go.dev/golang.org/x/tools/cmd/stringer' },
  { name: 'generic', file: 'Code generated by', url: '' },
];
---

<div>
  <div class="text-center" style="margin-bottom: 3rem;">
    <h2 class="section-title">11 generators. One filter.</h2>
    <p class="section-desc">Detects output from every major Go code generation tool.</p>
  </div>

  <div class="generator-grid">
    {generators.map((gen) => (
      <div class="generator-card">
        <div class="generator-name">
          {gen.url ? (
            <a href={gen.url} target="_blank" rel="noopener noreferrer" class="generator-link">{gen.name}</a>
          ) : (
            gen.name
          )}
        </div>
        <div class="generator-file">{gen.file}</div>
      </div>
    ))}
  </div>

  <p class="generator-attribution">
    Built by <a href="https://larsartmann.com" target="_blank" rel="noopener noreferrer" class="generator-link">LarsArtmann</a>
  </p>
</div>
