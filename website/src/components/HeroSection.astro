---
import { siteConfig } from '../data/config';
import { generatorCount } from '../data/generators';
import { heroCode } from '../data/hero-code';
import Icon from './Icon.astro';

async function getGitHubStars(): Promise<number | null> {
  try {
    const response = await fetch('https://api.github.com/repos/LarsArtmann/gogenfilter', {
      headers: {
        'Accept': 'application/vnd.github.v3+json',
      },
    });
    if (!response.ok) return null;
    const data = await response.json();
    return data.stargazers_count as number;
  } catch {
    return null;
  }
}

const stars = await getGitHubStars();
const starsText = stars !== null ? `${stars} Stars` : 'Star on GitHub';

const importPath = siteConfig.github.replace('https://github.com/', 'github.com/') + '/v3';

const highlightedCode = `<span class="text-[#bd93f9]">package</span> <span class="text-text-secondary">main</span>

<span class="text-[#bd93f9]">import</span> (
    <span class="text-[#f1fa8c]">"fmt"</span>
    <span class="text-[#8be9fd]">"${importPath}"</span>
)

<span class="text-[#ff79c6]">func</span> <span class="text-[#50fa7b]">main</span>() {
    opts, err := gogenfilter.<span class="text-[#50fa7b]">WithFilterOptions</span>(gogenfilter.FilterAll)
    if err != nil {
        panic(err)
    }
    f, err := gogenfilter.<span class="text-[#50fa7b]">NewFilter</span>(opts)
    if err != nil {
        panic(err)
    }

    filtered, _ := f.<span class="text-[#50fa7b]">Filter</span>(<span class="text-[#f1fa8c]">"db/models.go"</span>)
    fmt.<span class="text-[#50fa7b]">Println</span>(filtered) <span class="text-[#6272a4]">// true — sqlc generated</span>
}`;
---

<section class="relative flex items-center justify-center overflow-hidden pt-36 pb-20">
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-accent/8 blur-[120px] rounded-full pointer-events-none"></div>
  <div class="absolute top-1/3 -left-20 w-[420px] h-[420px] bg-amber/8 blur-[130px] rounded-full pointer-events-none"></div>
  <div class="relative max-w-4xl xl:max-w-6xl mx-auto px-6 text-center">
    <div class="flex items-center justify-center gap-3 mb-7 flex-wrap">
      <a class="inline-flex items-center gap-1.5 px-3.5 py-1.5 border border-border rounded-md text-text-secondary text-sm font-medium no-underline hover:border-accent hover:text-accent transition-all duration-150" href={siteConfig.github} target="_blank" rel="noopener">
        <Icon name="star" size={14} />
        {starsText}
      </a>
      <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-md text-amber text-sm font-medium bg-amber/10">
        <Icon name="check" size={14} />
        Free &amp; MIT licensed
      </span>
    </div>
    <h1 class="text-[clamp(2.75rem,8vw,4.75rem)] font-bold tracking-tighter leading-[1.05] mb-6">
      <span>Skip the </span><span class="bg-gradient-to-r from-accent via-accent-light to-amber bg-clip-text text-transparent">generated</span><span> noise.</span>
    </h1>

    <p class="text-[clamp(1.15rem,2.5vw,1.35rem)] text-text-secondary max-w-3xl mx-auto mb-10 leading-relaxed">
      Detect and filter auto-generated Go code files from
      <em class="not-italic text-text-primary font-medium">sqlc</em>, <em class="not-italic text-text-primary font-medium">protobuf</em>, <em class="not-italic text-text-primary font-medium">templ</em>, <em class="not-italic text-text-primary font-medium">mockgen</em>,
      and {generatorCount - 4} more tools.
      Built for linters and static analysis.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="/getting-started/installation/" data-astro-prefetch class="px-6 py-3 bg-accent text-bg-primary font-semibold rounded-lg text-base hover:bg-accent-hover transition-colors duration-150 inline-flex items-center gap-2 border-none cursor-pointer">Get Started &rarr;</a>
      <div class="flex items-center gap-2 py-2.5 px-4 rounded-lg bg-bg-card-solid border border-border font-mono text-sm text-text-primary select-all">$ go get {siteConfig.github.replace('https://github.com', 'github.com')}/v3</div>
    </div>

    <div class="relative max-w-xl mx-auto">
      <div class="absolute -inset-4 bg-gradient-to-r from-accent/10 via-amber/8 to-accent/10 rounded-2xl blur-6 pointer-events-none"></div>
      <div class="relative rounded-xl border border-border bg-bg-code shadow-2xl overflow-hidden code-preview">
        <div class="flex items-center gap-1.5 px-4 py-3 border-b border-border">
          {Array(3).fill(null).map(() => (
            <span class="w-3 h-3 rounded-full bg-code-dot"></span>
          ))}
          <span class="ml-3 text-xs text-text-muted font-mono">main.go</span>
        </div>
        <pre class="p-4 text-left text-sm font-mono leading-relaxed overflow-x-auto relative"><code id="hero-code" set:html={highlightedCode} /></pre>
        <button class="absolute top-2 right-2 bg-code-inline-bg/80 border border-border rounded-md text-text-muted px-1.5 py-1.5 cursor-pointer text-xs font-mono hover:text-text-primary hover:border-border-hover transition-all duration-150 opacity-0 [.code-preview:hover_&]:opacity-100" id="copy-btn" data-code={heroCode} aria-label="Copy code to clipboard">Copy</button>
      </div>
    </div>
  </div>
</section>

<script is:inline src="/js/copy-code.js"></script>
