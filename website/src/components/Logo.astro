---
export interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 32, height = 32, class: className } = Astro.props;
---

<svg class={className} width={width} height={height} viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="gogenfilter logo">
  <defs>
    <linearGradient id="ggf-mark" x1="2" y1="2" x2="26" y2="26" gradientUnits="userSpaceOnUse">
      <stop stop-color="#22d3ee" />
      <stop offset="1" stop-color="#0891b2" />
    </linearGradient>
  </defs>
  <rect width="28" height="28" rx="7" fill="url(#ggf-mark)" />
  <path d="M6 8.5H22L17 14.5V20L14 23L11 20V14.5Z" fill="#0a0908" fill-opacity="0.92" />
</svg>
