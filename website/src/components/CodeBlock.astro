---
export interface Props {
  code: string;
  filename?: string;
}

const { code, filename } = Astro.props;
---

<div class="rounded-xl border border-border bg-bg-code overflow-hidden">
  {filename && (
    <div class="px-4 py-2 border-b border-border text-xs text-text-muted font-mono">
      {filename}
    </div>
  )}
  <pre class="p-4 text-sm font-mono text-text-secondary overflow-x-auto"><code>{code}</code></pre>
</div>
