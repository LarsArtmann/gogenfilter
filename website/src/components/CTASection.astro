---
import Icon from './Icon.astro';
import SectionHeader from './SectionHeader.astro';
import { siteConfig } from '../data/config';
---

<div class="relative -mx-6 px-6 py-14 rounded-none sm:rounded-2xl sm:mx-0 overflow-hidden border border-border">
  <div class="absolute inset-0 bg-gradient-to-br from-accent/10 via-transparent to-amber/10 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-[500px] h-[300px] bg-accent/10 blur-[100px] rounded-full pointer-events-none" aria-hidden="true"></div>
  <SectionHeader title="Three lines. That's the whole API." subtitle="Free, MIT-licensed, and ready to drop into your next analyzer." />
  <div class="relative text-center">
    <div class="flex items-center justify-center gap-4 flex-wrap">
      <a href="/getting-started/installation/" data-astro-prefetch class="px-8 py-4 bg-accent text-bg-primary font-semibold rounded-lg text-base hover:bg-accent-hover transition-colors duration-150 inline-flex items-center gap-2 border-none cursor-pointer">
        Read the Docs
        <Icon name="arrow-right" size={16} />
      </a>
      <a href="/getting-started/quick-start/" data-astro-prefetch class="px-6 py-4 border border-text-secondary text-text-secondary font-medium rounded-lg text-base hover:border-text-primary hover:text-text-primary transition-colors duration-150 inline-flex items-center gap-2 no-underline">
        Quick Start
        <Icon name="arrow-right" size={16} />
      </a>
      <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="px-6 py-4 text-text-secondary font-medium rounded-lg text-base hover:text-text-primary transition-colors duration-150 inline-flex items-center gap-2 no-underline">
        <Icon name="github" size={18} />
        View source
      </a>
    </div>
  </div>
</div>
