---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../data/config';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const ogDesc = siteConfig.ogDescription.replace('{count}', '11');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteConfig.description} />
    <title>{title}</title>
    <meta property="og:title" content={siteConfig.name} />
    <meta property="og:description" content={ogDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteConfig.siteUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteConfig.name} />
    <meta name="twitter:description" content={ogDesc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={siteConfig.siteUrl} />
    <!-- Analytics (Plausible) -->
    <script defer data-domain="gogenfilter.lars.software" src="https://plausible.io/js/script.js"></script>
  </head>
  <body class="font-sans bg-bg-primary text-text-secondary antialiased leading-relaxed">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "gogenfilter",
      "description": siteConfig.description,
      "url": siteConfig.siteUrl,
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Go",
      "programmingLanguage": "Go",
      "license": "https://opensource.org/licenses/MIT",
      "author": {
        "@type": "Person",
        "name": "LarsArtmann",
        "url": siteConfig.author.url
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    })} />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
