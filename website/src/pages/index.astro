---
import LandingLayout from '../layouts/LandingLayout.astro';
import GeneratorGrid from '../components/GeneratorGrid.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
---

<LandingLayout title="gogenfilter — Detect & Filter Auto-Generated Go Code">
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-inner">
      <div class="badge">
        <span class="badge-dot"></span>
        Open Source &middot; MIT License &middot; Go 1.26+
      </div>

      <h1 class="hero-title">
        <span>Skip the </span>
        <span class="hero-title-highlight">generated</span>
        <br />
        <span>noise.</span>
      </h1>

      <p class="hero-subtitle">
        Detect and filter auto-generated Go code files from
        <em>sqlc</em>, <em>protobuf</em>, <em>templ</em>, <em>mockgen</em>,
        and 7 more tools.
        Built for linters and static analysis.
      </p>

      <div class="hero-actions">
        <a href="/docs/getting-started/installation/" class="btn-primary">Get Started &rarr;</a>
        <div class="install-cmd">$ go get github.com/LarsArtmann/gogenfilter</div>
      </div>

      <div class="code-preview-wrapper">
        <div class="code-preview-glow"></div>
        <div class="code-preview">
          <div class="code-preview-bar">
            <span class="code-dot"></span>
            <span class="code-dot"></span>
            <span class="code-dot"></span>
            <span class="code-filename">main.go</span>
          </div>
          <pre class="code-content"><code set:html={`<span class="kw">package</span> <span class="typ">main</span>

<span class="kw">import</span> (
    <span class="str">"fmt"</span>
    <span class="pkg">"github.com/LarsArtmann/gogenfilter"</span>
)

<span class="kw">func</span> <span class="fn">main</span>() {
    f := gogenfilter.<span class="fn">NewFilter</span>(
        gogenfilter.<span class="fn">Enabled</span>(),
        gogenfilter.<span class="fn">WithFilterOptions</span>(gogenfilter.FilterAll),
    )

    filtered, _ := f.<span class="fn">ShouldFilter</span>(<span class="str">"db/models.go"</span>)
    fmt.<span class="fn">Println</span>(filtered) <span class="cmt">// true — sqlc generated</span>
}`} /></pre>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <GeneratorGrid />
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <FeatureGrid />
    </div>
  </section>

  <section class="section">
    <div class="section-inner-sm text-center">
      <h2 class="section-title">Two-phase detection.</h2>
      <p class="section-desc">Filename first, content second. Most files are classified without reading a single byte.</p>

      <div class="phase-grid">
        <div class="phase-card">
          <div class="phase-header">
            <div class="phase-badge phase-badge-p1">P1</div>
            <h3 class="phase-title">Phase 1: Filename</h3>
          </div>
          <p class="phase-desc">
            Match suffixes like <code class="inline">.pb.go</code>, <code class="inline">_templ.go</code>, <code class="inline">wire_gen.go</code>
          </p>
          <span class="phase-tag">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Zero I/O — no file reads
          </span>
        </div>

        <div class="phase-card">
          <div class="phase-header">
            <div class="phase-badge phase-badge-p2">P2</div>
            <h3 class="phase-title">Phase 2: Content</h3>
          </div>
          <p class="phase-desc">
            Scan for <code class="inline">Code generated by</code> markers and tool-specific patterns
          </p>
          <span class="phase-tag phase-tag-amber">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Only runs when Phase 1 is inconclusive
          </span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner-sm text-center">
      <h2 class="section-title">Built for real tools.</h2>
      <p class="section-desc">Drop it into any linter, analyzer, or CI pipeline.</p>

      <div class="usecase-grid">
        <div class="usecase-card">
          <div class="usecase-emoji">&#x2699;&#xFE0F;</div>
          <h3 class="usecase-title">Linters</h3>
          <p class="usecase-desc">Skip generated files in static analysis</p>
        </div>
        <div class="usecase-card">
          <div class="usecase-emoji">&#x1F4CA;</div>
          <h3 class="usecase-title">Code Quality</h3>
          <p class="usecase-desc">Exclude generated code from metrics</p>
        </div>
        <div class="usecase-card">
          <div class="usecase-emoji">&#x1F6E0;&#xFE0F;</div>
          <h3 class="usecase-title">CI / CD</h3>
          <p class="usecase-desc">Filter noise from review tooling</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta">
    <div class="section-inner-sm text-center">
      <h2 class="section-title">Start filtering in seconds.</h2>
      <p class="section-desc">Three lines to filter all generated code from your project.</p>
      <a href="/docs/getting-started/installation/" class="btn-primary">
        Read the Docs
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </section>
</LandingLayout>
