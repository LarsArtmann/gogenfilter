{
  "threshold": 0,
  "reporters": ["consoleFull"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.astro/**",
    "**/flake.lock"
  ],
  "format": ["html", "typescript", "css", "markdown"],
  "formatsExts": {
    "html": ["astro", "mdx"]
  },
  "minLines": 2,
  "minTokens": 20,
  "absolute": true
}
