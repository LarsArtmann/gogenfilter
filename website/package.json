{
  "name": "gogenfilter-website",
  "version": "1.0.0",
  "private": true,
  "description": "Website and documentation for gogenfilter — detect and filter auto-generated Go code files",
  "keywords": [
    "astro",
    "code-generation",
    "code-quality",
    "go",
    "gogenfilter",
    "golang",
    "starlight",
    "static-analysis"
  ],
  "homepage": "https://gogenfilter.lars.software",
  "bugs": "https://github.com/LarsArtmann/gogenfilter/issues",
  "license": "MIT",
  "author": "LarsArtmann <lars@larsartmann.com> (https://larsartmann.com/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/LarsArtmann/gogenfilter.git",
    "directory": "website"
  },
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/fix-csp.mjs",
    "preview": "astro preview",
    "typecheck": "astro check",
    "clean": "rm -rf dist .astro node_modules/.cache",
    "validate:docs": "md-go-validator -f table src/content/docs/",
    "dedup": "bash scripts/dedup.sh",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.41.1",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "astro-og-canvas": "^0.12.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "html-validate": "^11.5.3",
    "jscpd": "^5.0.11",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "devalue": "5.8.1",
    "vite": "7.3.2",
    "yaml": "2.8.3"
  }
}
