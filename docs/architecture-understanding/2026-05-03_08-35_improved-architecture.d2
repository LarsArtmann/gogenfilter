shape: sequence_diagram
direction: down

gogenfilter: {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"

  API: {
    shape: rectangle
    style.fill: "#BBDEFB"

    NewFilter: {
      shape: rectangle
      style.fill: "#90CAF9"
    }
    ShouldFilter: {
      shape: rectangle
      style.fill: "#90CAF9"
    }
    WalkAndFilter: {
      shape: rectangle
      style.fill: "#64B5F6"
      style.stroke: "#1565C0"
      style.stroke-dash: 3
    }
    DetectReason: {
      shape: rectangle
      style.fill: "#90CAF9"
    }
  }

  Core: {
    shape: rectangle
    style.fill: "#C8E6C9"

    DetectorsTable: {
      shape: cylinder
      style.fill: "#A5D6A7"
    }
    TwoPhaseEngine: {
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    PatternMatcher: {
      shape: rectangle
      style.fill: "#A5D6A7"
    }
  }

  Infrastructure: {
    shape: rectangle
    style.fill: "#FFE0B2"

    fsFS: {
      shape: diamond
      style.fill: "#FFCC80"
    }
    Metrics: {
      shape: rectangle
      style.fill: "#FFCC80"
    }
    ErrorSystem: {
      shape: rectangle
      style.fill: "#FFCC80"
    }
    ProjectRoot: {
      shape: rectangle
      style.fill: "#FFCC80"
    }
    SQLCConfig: {
      shape: rectangle
      style.fill: "#FFCC80"
    }
  }
}

Consumer: {
  shape: person
  style.fill: "#E1BEE7"
}

Consumer -> API.NewFilter: functional options
API.NewFilter -> Core.DetectorsTable: lookup options

Consumer -> API.ShouldFilter: single file
API.ShouldFilter -> Core.PatternMatcher: include/exclude
Core.PatternMatcher -> Core.TwoPhaseEngine: pass
Core.TwoPhaseEngine -> Infrastructure.Metrics: record result
API.ShouldFilter -> Consumer: (bool, error)

Consumer -> API.WalkAndFilter: directory path
API.WalkAndFilter -> Infrastructure.fsFS: walk tree
Infrastructure.fsFS -> Core.TwoPhaseEngine: each file
Core.TwoPhaseEngine -> Infrastructure.Metrics: record
API.WalkAndFilter -> Consumer: "map[string]FilterReason"

Consumer -> API.DetectReason: "path + content (no I/O)"
API.DetectReason -> Core.TwoPhaseEngine: query table
Core.TwoPhaseEngine -> Consumer: FilterReason
