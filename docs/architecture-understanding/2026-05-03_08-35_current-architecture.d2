shape: sequence_diagram
direction: down

gogenfilter: {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"

  API: {
    shape: rectangle
    style.fill: "#BBDEFB"

    NewFilter: {
      shape: rectangle
      style.fill: "#90CAF9"
    }
    ShouldFilter: {
      shape: rectangle
      style.fill: "#90CAF9"
    }
    DetectReason: {
      shape: rectangle
      style.fill: "#90CAF9"
    }
  }

  Core: {
    shape: rectangle
    style.fill: "#C8E6C9"

    DetectorsTable: {
      shape: cylinder
      style.fill: "#A5D6A7"
    }
    TwoPhaseEngine: {
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    PatternMatcher: {
      shape: rectangle
      style.fill: "#A5D6A7"
    }
  }

  Infrastructure: {
    shape: rectangle
    style.fill: "#FFE0B2"

    fsFS: {
      shape: diamond
      style.fill: "#FFCC80"
    }
    Metrics: {
      shape: rectangle
      style.fill: "#FFCC80"
    }
    ErrorSystem: {
      shape: rectangle
      style.fill: "#FFCC80"
    }
    ProjectRoot: {
      shape: rectangle
      style.fill: "#FFCC80"
    }
    SQLCConfig: {
      shape: rectangle
      style.fill: "#FFCC80"
    }
  }
}

Consumer: {
  shape: person
  style.fill: "#E1BEE7"
}

Consumer -> API.NewFilter: functional options
API.NewFilter -> Core.DetectorsTable: lookup options

Consumer -> API.ShouldFilter: file path
API.ShouldFilter -> Core.PatternMatcher: include/exclude
Core.PatternMatcher -> Core.TwoPhaseEngine: pass
Core.TwoPhaseEngine -> Core.DetectorsTable: query
Core.TwoPhaseEngine -> Infrastructure.fsFS: read content
Infrastructure.fsFS -> Core.TwoPhaseEngine: content
Core.TwoPhaseEngine -> Infrastructure.Metrics: record result
API.ShouldFilter -> Consumer: (bool, error)

Consumer -> API.DetectReason: path + content
API.DetectReason -> Core.TwoPhaseEngine: no I/O
Core.TwoPhaseEngine -> Consumer: FilterReason

Infrastructure.ProjectRoot -> Infrastructure.ErrorSystem: errors
Infrastructure.SQLCConfig -> Infrastructure.ErrorSystem: errors
